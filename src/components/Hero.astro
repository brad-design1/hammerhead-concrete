---
// Hero section with strong value proposition
---

<section class="relative min-h-[85vh] flex items-center bg-brand-slate overflow-hidden">
  <!-- Background Image Overlay -->
  <div class="absolute inset-0 bg-gradient-to-r from-brand-slate via-brand-slate/95 to-brand-slate/70"></div>
  
  <!-- Concrete texture effect -->
  <div class="absolute inset-0 opacity-10 concrete-texture"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="max-w-3xl">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-orange-500/10 border border-orange-500/20 rounded-full px-4 py-2 mb-6">
        <span class="w-2 h-2 bg-orange-500 rounded-full animate-pulse"></span>
        <span class="text-orange-400 text-sm font-medium">Serving Brownwood & Surrounding Counties</span>
      </div>
      
      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
        Concrete Done Right.
        <span class="block text-brand-silver">Fair Pricing, Always.</span>
      </h1>
      
      <!-- Subheadline -->
      <p class="text-xl text-gray-300 mb-8 max-w-2xl">
        10+ years of experience. Zero complaints. Driveways, patios, sidewalks, foundations, and decorative concrete for homeowners across Brown County.
      </p>
      
      <!-- Trust indicators -->
      <div class="flex flex-wrap items-center gap-6 mb-10">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-orange-500" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          <span class="text-gray-300 text-sm">100% Transparent Pricing</span>
        </div>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-orange-500" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          <span class="text-gray-300 text-sm">Free On-Site Estimates</span>
        </div>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-orange-500" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          <span class="text-gray-300 text-sm">Locally Owned & Operated</span>
        </div>
      </div>
      
      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#quote" class="btn-primary text-lg px-8 py-4">
          Get Your Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
        <a href="tel:+13254308305" class="btn-secondary border-white/30 text-white hover:bg-white hover:text-brand-slate text-lg px-8 py-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          (325) 430-8305
        </a>
      </div>
    </div>
  </div>
  
  <!-- Decorative element -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent"></div>
</section>
