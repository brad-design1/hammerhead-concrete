---
// Quote Calculator - Lead capture with transparent pricing message
// Voice: Straight-talking, anti-contractor-BS positioning
---

<section id="quote" class="section bg-brand-concrete">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
      
      <!-- Left: Value Proposition -->
      <div class="lg:sticky lg:top-24">
        <span class="text-orange-500 font-semibold text-sm uppercase tracking-wider">No Games</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold text-brand-slate">
          Know What You're Paying For
        </h2>
        <p class="mt-4 text-lg text-gray-600 leading-relaxed">
          Most contractors give you a number and hope you don't ask questions. 
          We give you a <strong>line-by-line breakdown</strong> — concrete yardage, 
          labor hours, materials, everything. You'll know exactly where your money goes.
        </p>
        
        <!-- The difference -->
        <div class="mt-8 p-6 bg-white rounded-xl border border-gray-100">
          <h3 class="font-semibold text-brand-slate mb-4">Here's what a Hammerhead quote looks like:</h3>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between text-gray-600">
              <span>Concrete (4.2 yards @ $145/yd)</span>
              <span class="font-medium">$609</span>
            </div>
            <div class="flex justify-between text-gray-600">
              <span>Rebar & mesh</span>
              <span class="font-medium">$185</span>
            </div>
            <div class="flex justify-between text-gray-600">
              <span>Forms & stakes</span>
              <span class="font-medium">$120</span>
            </div>
            <div class="flex justify-between text-gray-600">
              <span>Labor (6 hours @ $65/hr)</span>
              <span class="font-medium">$390</span>
            </div>
            <div class="flex justify-between text-gray-600">
              <span>Finish work & cleanup</span>
              <span class="font-medium">$175</span>
            </div>
            <div class="border-t border-gray-200 pt-3 flex justify-between font-semibold text-brand-slate">
              <span>Total</span>
              <span>$1,479</span>
            </div>
          </div>
          <p class="mt-4 text-xs text-gray-500 italic">Example quote for a 12×20 patio slab. Your project may vary.</p>
        </div>
        
        <!-- Trust points -->
        <div class="mt-8 space-y-4">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-orange-500 rounded-lg flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-brand-slate">No Bait-and-Switch</h4>
              <p class="text-sm text-gray-600">The price we quote is the price you pay. Unless you change the scope, your number doesn't change.</p>
            </div>
          </div>
          
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-orange-500 rounded-lg flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" viewBox="0 0 20 20" fill="currentColor">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-brand-slate">Talk to Dain, Not a Call Center</h4>
              <p class="text-sm text-gray-600">When you call, you get the guy who's going to pour your concrete. <a href="tel:+13254308305" class="text-orange-500 font-semibold">(325) 430-8305</a></p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Right: Quote Form -->
      <div class="bg-white rounded-2xl shadow-xl p-8 md:p-10">
        <h3 class="text-xl font-bold text-brand-slate mb-2">Get Your Free Estimate</h3>
        <p class="text-gray-600 mb-6">Takes 30 seconds. We'll get back to you within 24 hours.</p>
        
        <form id="quote-form" class="space-y-6">
          <!-- Project Type -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">What do you need?</label>
            <select name="projectType" required class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors">
              <option value="">Select your project...</option>
              <option value="driveway">Driveway (new or replace)</option>
              <option value="patio">Patio or Porch</option>
              <option value="sidewalk">Sidewalk</option>
              <option value="foundation">Foundation / Slab</option>
              <option value="steps">Steps or Ramp</option>
              <option value="decorative">Stamped / Stained Concrete</option>
              <option value="other">Something Else</option>
            </select>
          </div>
          
          <!-- Approximate Size -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">About how big? (square feet)</label>
            <input 
              type="number" 
              name="squareFeet" 
              placeholder="e.g., 400" 
              required
              min="10"
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors"
            />
            <p class="mt-1 text-xs text-gray-500">Not sure? Just guess — we'll measure it when we come out.</p>
          </div>
          
          <!-- Finish Type -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Finish type</label>
            <div class="grid grid-cols-2 gap-3">
              <label class="relative flex items-center p-4 border border-gray-200 rounded-lg cursor-pointer hover:border-orange-500 transition-colors">
                <input type="radio" name="finish" value="standard" class="sr-only peer" checked />
                <span class="peer-checked:text-orange-500">
                  <span class="block font-medium">Standard</span>
                  <span class="block text-xs text-gray-500">Broom finish</span>
                </span>
                <span class="absolute inset-0 rounded-lg border-2 border-transparent peer-checked:border-orange-500"></span>
              </label>
              <label class="relative flex items-center p-4 border border-gray-200 rounded-lg cursor-pointer hover:border-orange-500 transition-colors">
                <input type="radio" name="finish" value="decorative" class="sr-only peer" />
                <span class="peer-checked:text-orange-500">
                  <span class="block font-medium">Decorative</span>
                  <span class="block text-xs text-gray-500">Stamped/Stained</span>
                </span>
                <span class="absolute inset-0 rounded-lg border-2 border-transparent peer-checked:border-orange-500"></span>
              </label>
            </div>
          </div>
          
          <!-- Contact Info -->
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Your name</label>
              <input 
                type="text" 
                name="name" 
                placeholder="John Smith" 
                required
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors"
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Phone</label>
              <input 
                type="tel" 
                name="phone" 
                placeholder="(325) 555-1234" 
                required
                class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors"
              />
            </div>
          </div>
          
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Email</label>
            <input 
              type="email" 
              name="email" 
              placeholder="john@example.com" 
              required
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors"
            />
          </div>
          
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Where's the project?</label>
            <input 
              type="text" 
              name="city" 
              placeholder="Brownwood, TX" 
              required
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors"
            />
          </div>
          
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Anything else? (optional)</label>
            <textarea 
              name="details" 
              rows="3"
              placeholder="Slope issues? Existing concrete removal? Timeline?"
              class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition-colors resize-none"
            ></textarea>
          </div>
          
          <!-- Submit -->
          <button 
            type="submit" 
            class="w-full btn-primary text-lg py-4 flex items-center justify-center gap-2"
          >
            Send My Project Details
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </button>
          
          <p class="text-center text-xs text-gray-500">
            We'll respond within 24 hours with a detailed, itemized estimate.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('quote-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);
    
    // Success message
    alert('Got it! Dain will review your project and get back to you within 24 hours with a detailed, itemized estimate. No pressure, no sales pitch — just numbers.');
    form.reset();
  });
</script>
