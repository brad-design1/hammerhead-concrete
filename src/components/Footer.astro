---
// Footer component
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-dark text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12">
      
      <!-- Brand -->
      <div class="lg:col-span-2">
        <div class="flex items-center gap-3 mb-4">
          <img 
            src="/logo.png" 
            alt="Hammerhead Concrete" 
            class="h-12 w-auto brightness-0 invert"
          />
          <div>
            <span class="block text-lg font-bold leading-tight">HAMMERHEAD</span>
            <span class="block text-sm font-medium text-gray-400 -mt-1">CONCRETE</span>
          </div>
        </div>
        <p class="text-gray-400 max-w-md">
          Professional concrete contractor serving Brownwood, TX and surrounding areas. 
          10+ years of experience. Transparent pricing. Quality you can trust.
        </p>
        
        <!-- Social Links -->
        <div class="flex items-center gap-4 mt-6">
          <a 
            href="https://www.facebook.com/profile.php?id=61581587768915" 
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center hover:bg-orange-500 transition-colors"
            aria-label="Facebook"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
      </div>
      
      <!-- Services -->
      <div>
        <h4 class="font-semibold text-white mb-4">Services</h4>
        <ul class="space-y-2">
          <li><a href="#services" class="text-gray-400 hover:text-orange-400 transition-colors">Driveways</a></li>
          <li><a href="#services" class="text-gray-400 hover:text-orange-400 transition-colors">Patios & Porches</a></li>
          <li><a href="#services" class="text-gray-400 hover:text-orange-400 transition-colors">Sidewalks</a></li>
          <li><a href="#services" class="text-gray-400 hover:text-orange-400 transition-colors">Foundations</a></li>
          <li><a href="#services" class="text-gray-400 hover:text-orange-400 transition-colors">Decorative Concrete</a></li>
          <li><a href="#services" class="text-gray-400 hover:text-orange-400 transition-colors">Steps & Ramps</a></li>
        </ul>
      </div>
      
      <!-- Contact -->
      <div>
        <h4 class="font-semibold text-white mb-4">Contact</h4>
        <ul class="space-y-3">
          <li>
            <a href="tel:+13254308305" class="flex items-center gap-2 text-gray-400 hover:text-orange-400 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              (325) 430-8305
            </a>
          </li>
          <li>
            <a href="mailto:daincox040@gmail.com" class="flex items-center gap-2 text-gray-400 hover:text-orange-400 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              daincox040@gmail.com
            </a>
          </li>
          <li class="flex items-start gap-2 text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Brownwood, TX<br />& surrounding areas (30 mi)</span>
          </li>
        </ul>
      </div>
    </div>
    
    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-gray-400">
        © {currentYear} Hammerhead Concrete. All rights reserved.
      </p>
      <p class="text-sm text-gray-500">
        Est. 2026 · Brownwood, Texas
      </p>
    </div>
  </div>
</footer>
