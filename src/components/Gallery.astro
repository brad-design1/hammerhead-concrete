---
// Project gallery showcasing completed work
// Images will be added from the job photos
const projects = [
  { id: 1, title: "Residential Driveway", type: "Driveway", image: "/projects/job1.jpg" },
  { id: 2, title: "Backyard Patio", type: "Patio", image: "/projects/job2.jpg" },
  { id: 3, title: "Commercial Sidewalk", type: "Sidewalk", image: "/projects/job3.jpg" },
  { id: 4, title: "Stamped Concrete Patio", type: "Decorative", image: "/projects/job4.jpg" },
  { id: 5, title: "Foundation Slab", type: "Foundation", image: "/projects/job5.jpg" },
  { id: 6, title: "Entry Steps", type: "Steps", image: "/projects/job6.jpg" },
];
---

<section id="work" class="section bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-orange-500 font-semibold text-sm uppercase tracking-wider">Our Work</span>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold text-brand-slate">
        Quality You Can See
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        Every project completed with care. Here's a sample of our recent work across Brown County.
      </p>
    </div>
    
    <!-- Gallery Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <div class="group relative overflow-hidden rounded-2xl bg-gray-100 aspect-[4/3]">
          <!-- Placeholder for actual project photos -->
          <div class="absolute inset-0 bg-gradient-to-br from-brand-slate to-brand-navy flex items-center justify-center">
            <span class="text-6xl opacity-20">🏗️</span>
          </div>
          
          <!-- Hover Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-brand-slate via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <span class="text-orange-400 text-sm font-medium">{project.type}</span>
              <h3 class="text-white font-semibold text-lg">{project.title}</h3>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <!-- View More / CTA -->
    <div class="mt-12 text-center">
      <p class="text-gray-600 mb-4">Want to see more? Follow us on Facebook for the latest projects.</p>
      <a 
        href="https://www.facebook.com/profile.php?id=61581587768915" 
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-orange-500 font-semibold hover:text-orange-600 transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        View Our Facebook Page
      </a>
    </div>
  </div>
</section>
