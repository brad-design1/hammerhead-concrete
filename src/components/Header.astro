---
// Header component with mobile nav
---

<header class="fixed top-0 left-0 right-0 z-40 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">
        <img 
          src="/logo.png" 
          alt="Hammerhead Concrete" 
          class="h-10 md:h-12 w-auto"
        />
        <div class="hidden sm:block">
          <span class="block text-lg font-bold text-brand-slate leading-tight">HAMMERHEAD</span>
          <span class="block text-sm font-medium text-brand-steel -mt-1">CONCRETE</span>
        </div>
      </a>
      
      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="#services" class="text-sm font-medium text-gray-600 hover:text-brand-slate transition-colors">Services</a>
        <a href="#work" class="text-sm font-medium text-gray-600 hover:text-brand-slate transition-colors">Our Work</a>
        <a href="#quote" class="text-sm font-medium text-gray-600 hover:text-brand-slate transition-colors">Get Quote</a>
        <a href="#about" class="text-sm font-medium text-gray-600 hover:text-brand-slate transition-colors">About</a>
      </nav>
      
      <!-- CTA -->
      <div class="flex items-center gap-4">
        <a href="tel:+13254308305" class="hidden md:flex items-center gap-2 text-sm font-semibold text-brand-slate">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          (325) 430-8305
        </a>
        <a href="#quote" class="btn-primary text-sm px-4 py-2">
          Free Estimate
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 md:h-20"></div>
